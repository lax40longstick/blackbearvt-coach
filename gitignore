# =============================================================================
# Bear Den Coach HQ — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS — never commit these. Anything matching is a security incident.
# -----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.production
.env.*.local
*.pem
*.key

# -----------------------------------------------------------------------------
# BUILD OUTPUTS — runtime-config.js is GENERATED on every Netlify deploy by
# `npm run build`. Keeping it in git means a stale committed copy can override
# the env vars (this caused the "Invalid API key" error on coach-app-hockey).
# -----------------------------------------------------------------------------
runtime-config.js
dist/
build/

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
jspm_packages/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# -----------------------------------------------------------------------------
