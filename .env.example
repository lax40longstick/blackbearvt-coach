# BenchBoss Coach HQ environment example
#
# Copy to `.env` and fill in values. Run `npm run config:build` to generate
# `runtime-config.js`, which is what the static frontend loads at runtime.

# -----------------------------------------------------------------------------
# Frontend (publishable) — these ship to the browser via runtime-config.js.
# -----------------------------------------------------------------------------
PUBLIC_APP_ENV=development
PUBLIC_APP_URL=http://localhost:3000

PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Analytics & monitoring (publishable)
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
PUBLIC_SENTRY_DSN=
PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05

# Cloudflare Turnstile site key (publishable)
PUBLIC_TURNSTILE_SITE_KEY=

# -----------------------------------------------------------------------------
# Server-side secrets — set these in Netlify → Site config → Environment vars.
# Never expose these to the browser, never commit real values.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (AI Practice Builder)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_RATE_LIMIT_PER_MINUTE=8

# Cloudflare Turnstile secret (server-side verify)
TURNSTILE_SECRET_KEY=

# Stripe subscription price IDs — create in Stripe Dashboard, paste here.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_ANNUAL=
STRIPE_PRICE_CLUB_MONTHLY=
STRIPE_PRICE_CLUB_ANNUAL=

# Marketplace one-time purchases use the same Stripe webhook as subscriptions
# (extended in patch.3 to handle mode=payment events). Per-plan price IDs live
# on the marketplace_plans table itself, not in env vars.

# Optional — direct Postgres for admin scripts only. Never exposed to the browser.
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xdscbxtqayiiucjucjip.supabase.co:5432/postgres
